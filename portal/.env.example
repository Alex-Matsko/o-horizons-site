# ============================================================
# 1C Portal — Environment Variables (.env.example)
# Скопируй в .env и заполни реальными значениями
# ============================================================

# --- PostgreSQL (портал) ---
PORTAL_DB_HOST=portal-db
PORTAL_DB_PORT=5432
PORTAL_DB_NAME=portal
PORTAL_DB_USER=portal
PORTAL_DB_PASS=CHANGE_ME_db_password
DATABASE_URL=postgresql://portal:CHANGE_ME_db_password@portal-db:5432/portal

# --- Redis ---
REDIS_HOST=portal-redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://:CHANGE_ME_redis_password@portal-redis:6379

# --- JWT ---
JWT_SECRET=CHANGE_ME_jwt_secret_min_64_chars
JWT_REFRESH_SECRET=CHANGE_ME_jwt_refresh_secret_min_64_chars
JWT_EXPIRES_IN=7d

# --- Email ---
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@o-horizons.com
SMTP_PASS=CHANGE_ME_smtp_password
EMAIL_FROM="1С Портал O-Horizons <noreply@o-horizons.com>"

# --- Портал ---
PORTAL_URL=https://1c.o-horizons.com
PORTAL_PORT=3001
FRONTEND_URL=https://1c.o-horizons.com
NODE_ENV=production
ADMIN_EMAIL=admin@o-horizons.com

# --- Telegram уведомления ---
TELEGRAM_BOT_TOKEN=CHANGE_ME_bot_token
TELEGRAM_ADMIN_CHAT_ID=CHANGE_ME_chat_id

# --- Сервер 1С ---
ONEC_SERVER_HOST=10.99.99.25
ONEC_SERVER_URL=http://10.99.99.25
ONEC_CLUSTER_PORT=1545
ONEC_CLUSTER_ID=CHANGE_ME_cluster_uuid
ONEC_TEMPLATES_PATH=/opt/1c/templates

# --- SSH для управления сервером 1С ---
# Пользователь portaldeploy (не root!) с sudo на скрипты
ONEC_SERVER_SSH_USER=portaldeploy
ONEC_SERVER_SSH_KEY_PATH=/root/.ssh/portal_deploy
ONEC_SCRIPT_PATH=/app/scripts/create-1c-db.sh

# --- API 1С (OData) ---
ONEC_API_USER=Администратор
ONEC_API_PASS=CHANGE_ME_onec_admin_password

# --- PostgreSQL сервер 1С ---
ONEC_PG_HOST=10.99.99.25
ONEC_PG_PORT=5432
ONEC_PG_USER=usr1cv8
ONEC_PG_PASS=CHANGE_ME_pg_password

# --- Apache / публикация ---
ONEC_APACHE_BASE_URL=https://1c.o-horizons.com/1c
ONEC_APACHE_CONF_DIR=/etc/apache2

# --- Бэкапы ---
BACKUP_DIR=/backups
BACKUP_RETENTION_DAYS=7

# --- Rate limiting ---
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# --- Scripts ---
SCRIPTS_PATH=/app/scripts

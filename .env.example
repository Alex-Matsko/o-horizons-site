# Copy to .env and fill in real values. Never commit .env to git!
# Also read by docker-compose for the `site` build args (NEXT_PUBLIC_* below).

# Baked into the Next.js client bundle at build time — safe to be public.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

SMTP_HOST=mail.o-horizons.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@o-horizons.com
SMTP_PASS=your_password_here
MAIL_TO=info@o-horizons.com
ALLOWED_ORIGIN=https://o-horizons.com

# Set to false to skip TLS certificate verification (e.g. self-signed or expired cert)
SMTP_TLS_REJECT_UNAUTHORIZED=false

# Telegram integration for site chat — leave all three empty to disable.
# Setup: create a bot via @BotFather, disable its privacy mode (/setprivacy),
# create a supergroup with "Topics" enabled, add the bot as admin with
# "Manage Topics", then register the webhook:
#   curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://o-horizons.com/api/telegram-webhook&secret_token=<TELEGRAM_WEBHOOK_SECRET>"
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# api.telegram.org is blocked from Russian IPs — set a proxy for outgoing
# Telegram API calls (createForumTopic/sendMessage) if the docker host is
# in RU. Not needed for the incoming webhook (Telegram connects to us, not
# the other way around). Leave empty if the host already has unblocked
# access. Must be a plain HTTP(S) or SOCKS5 proxy — a Telegram MTProto
# proxy link (t.me/proxy?...) will NOT work here, different protocol.
# Examples: http://user:pass@proxy-host:8080
#           socks5://user:pass@proxy-host:1080
TELEGRAM_PROXY_URL=

# App
NODE_ENV=production
PORT=3001
APP_URL=https://1c.o-horizons.com
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_LONG_RANDOM_STRING

# Database
PORTAL_DB_HOST=portal-db
PORTAL_DB_PORT=5432
PORTAL_DB_NAME=portal
PORTAL_DB_USER=portal_user
PORTAL_DB_PASSWORD=CHANGE_ME

# Redis
REDIS_HOST=portal-redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# Email
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@o-horizons.com
SMTP_PASS=CHANGE_ME
MAIL_FROM="O-Horizons Portal <noreply@o-horizons.com>"

# Telegram
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_ADMIN_CHAT_ID=CHANGE_ME

# 1C Server
ONEC_SERVER_HOST=192.168.1.XXX
ONEC_SERVER_SSH_USER=portal_deploy
ONEC_SERVER_SSH_KEY_PATH=/run/secrets/portal_ssh_key
ONEC_CLUSTER_NAME=default
ONEC_APACHE_BASE_URL=https://1c-internal.example.com
ONEC_API_USER=portal_api
ONEC_API_PASS=CHANGE_ME
ONEC_TEMPLATES_PATH=/opt/1c/templates

# Backups
BACKUP_LOCAL_PATH=/backups
BACKUP_RETENTION_DAYS=14

# Admin
ADMIN_EMAIL=admin@o-horizons.com

# PostgreSQL (портальная БД, отдельный инстанс)
DATABASE_URL=postgresql://portal_user:password@localhost:5433/portal_db

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_me_very_long_secret_here
JWT_REFRESH_SECRET=change_me_refresh_secret_here

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@o-horizons.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@o-horizons.com

# Фронтенд
FRONTEND_URL=https://1c.o-horizons.com

# 1С сервер
ONEC_SERVER_URL=http://your-1c-server
ONEC_ADMIN_USER=Admin
ONEC_ADMIN_PASS=your_1c_admin_password
ONEC_DEFAULT_VERSION=8.3.27
ONEC_CLUSTER_ID=your-cluster-guid-here

# PostgreSQL для 1С баз
DB_HOST_1C=localhost
DB_USER_1C=postgres
DB_PASS_1C=your_postgres_password

# Шаблоны CF-файлов
CF_BASE_PATH=/opt/1c/templates

# Бэкапы
BACKUP_PATH=/opt/1c-backups

# Порт backend
PORT=3010
LOG_LEVEL=info

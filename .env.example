# Copy to .env and fill in real values. Never commit .env to git!
# Also read by docker-compose for the `site` build args (NEXT_PUBLIC_* below).

# Baked into the Next.js client bundle at build time — safe to be public.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Analytics — also build-time NEXT_PUBLIC_* args; leave empty to disable.
# Yandex Metrika: create a counter at https://metrika.yandex.ru, put its
# numeric id here (e.g. 12345678).
NEXT_PUBLIC_YM_ID=
# Google Analytics 4: create a property at https://analytics.google.com,
# put its measurement id here (e.g. G-XXXXXXXXXX).
NEXT_PUBLIC_GA_ID=

SMTP_HOST=mail.o-horizons.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@o-horizons.com
SMTP_PASS=your_password_here
MAIL_TO=info@o-horizons.com
ALLOWED_ORIGIN=https://o-horizons.com

# Set to false to skip TLS certificate verification (e.g. self-signed or expired cert)
SMTP_TLS_REJECT_UNAUTHORIZED=false

# Telegram integration for site chat — leave both empty to disable.
# Setup: create a bot via @BotFather, disable its privacy mode (/setprivacy),
# create a supergroup with "Topics" enabled, add the bot as admin with
# "Manage Topics". No webhook to register — the manager's replies are
# fetched via long polling (getUpdates), since RU networks block inbound
# connections from Telegram's IPs just as much as outbound ones, so a
# webhook can never reach us here.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# api.telegram.org is blocked from Russian IPs — set a proxy for ALL
# Telegram API calls (createForumTopic/sendMessage/getUpdates) if the
# docker host is in RU. Leave empty if the host already has unblocked
# access. Must be a plain HTTP(S) or SOCKS5 proxy — a Telegram MTProto
# proxy link (t.me/proxy?...) will NOT work here, different protocol.
# See xray/config.example.json for routing this through your own VPN.
# Examples: http://user:pass@proxy-host:8080
#           socks5://xray:1080  (the bundled xray service, see docker-compose.yml)
TELEGRAM_PROXY_URL=

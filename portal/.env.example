# === Portal Database ===
PORTAL_DB_HOST=portal-db
PORTAL_DB_PORT=5432
PORTAL_DB_NAME=portal
PORTAL_DB_USER=portal_user
PORTAL_DB_PASSWORD=change_me_strong_password

# === Redis ===
REDIS_HOST=portal-redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# === JWT ===
JWT_SECRET=change_me_very_long_random_string_at_least_64_chars

# === 1C Server ===
ONEC_SERVER_URL=https://your-1c-server.example.com
ONEC_API_USER=portal_api
ONEC_API_PASSWORD=
ONEC_PG_HOST=your-1c-pg-host
ONEC_PG_USER=onec_user
ONEC_PG_PASSWORD=

# === SSH to 1C server (for database creation scripts) ===
ONEC_SSH_HOST=your-1c-server.example.com
ONEC_SSH_USER=portal_deploy

# === Email (SMTP) ===
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@o-horizons.com
SMTP_PASS=
SMTP_FROM=no-reply@o-horizons.com

# === Telegram ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# === Backups ===
BACKUP_LOCAL_PATH=/backups

# === App ===
FRONTEND_URL=https://1c.o-horizons.com
NODE_ENV=production
SCRIPTS_PATH=/app/scripts

# === Portal DB password (used by Docker) ===
PORTAL_DB_PASSWORD_DOCKER=change_me_strong_password

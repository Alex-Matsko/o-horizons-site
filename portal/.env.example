# ============================================================
# 1C Portal — Environment Variables
# Скопируй в portal/.env и заполни все значения
# ============================================================

# --- PostgreSQL (отдельный инстанс для портала) ---
PORTAL_DB_HOST=portal-db
PORTAL_DB_PORT=5432
PORTAL_DB_NAME=portal
PORTAL_DB_USER=portal
PORTAL_DB_PASS=CHANGE_ME_strong_password
DATABASE_URL=postgresql://portal:CHANGE_ME_strong_password@portal-db:5432/portal

# --- Redis (BullMQ очереди) ---
REDIS_HOST=portal-redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://:CHANGE_ME_redis_password@portal-redis:6379

# --- JWT ---
JWT_SECRET=CHANGE_ME_very_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# --- Email (SMTP для верификации и уведомлений) ---
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@o-horizons.com
SMTP_PASS=CHANGE_ME_smtp_password
EMAIL_FROM="1С Портал O-Horizons <noreply@o-horizons.com>"

# --- Портал (публичный URL) ---
PORTAL_URL=https://1c.o-horizons.com
PORTAL_PORT=3001
NODE_ENV=production

# --- Сервер 1С ---
# Хост сервера 1С (если на той же машине — localhost или IP)
ONEC_SERVER_HOST=127.0.0.1
# Порт кластера 1С (по умолчанию 1541)
ONEC_CLUSTER_PORT=1541
# Пользователь агента кластера 1С
ONEC_ADMIN_USER=admin
ONEC_ADMIN_PASS=CHANGE_ME_1c_admin_password
# Путь к ibcmd (утилита командной строки 1С)
ONEC_IBCMD_PATH=/opt/1cv8/x86_64/8.3.27.0/ibcmd
# Версия 1С по умолчанию для новых баз
ONEC_DEFAULT_VERSION=8.3.27

# --- PostgreSQL сервер 1С (для создания новых баз) ---
# ВНИМАНИЕ: это НЕ база портала, это PostgreSQL где хранятся базы 1С!
ONEC_PG_HOST=localhost
ONEC_PG_PORT=5432
ONEC_PG_USER=postgres
ONEC_PG_PASS=CHANGE_ME_1c_pg_password

# --- Apache / публикация баз ---
# Базовый URL под которым публикуются базы 1С
ONEC_APACHE_BASE_URL=https://1c.o-horizons.com/1c
# Путь к конфигам Apache vhost для публикации баз
ONEC_APACHE_CONF_DIR=/etc/apache2/conf.d

# --- SSH для управления сервером 1С (если 1С на отдельном хосте) ---
SSH_KEY_PATH=/root/.ssh/portal_deploy
SSH_1C_USER=portal_deploy
SSH_1C_HOST=

# --- Бэкапы ---
BACKUP_DIR=/backups
BACKUP_RETENTION_DAYS=7

# --- Rate limiting ---
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

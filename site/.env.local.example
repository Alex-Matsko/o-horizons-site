# Copy this file to .env.local and fill in the values

# Sanity CMS (optional — site works without it, Sanity pages show empty state)
# Create a project at https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Write token for `npm run seed:sanity` only (one-time content seed script).
# Create at https://sanity.io/manage -> API -> Tokens, permission "Editor".
# Server-only, never exposed to the browser — do not add NEXT_PUBLIC_ prefix.
SANITY_WRITE_TOKEN=

# Mailer microservice URL (used by API proxy routes)
# In Docker Compose: http://mailer:3001
# For local dev without Docker: http://localhost:3001
MAILER_URL=http://mailer:3001
